# Secrets & local-only config (DO NOT COMMIT)
# Option A: set WORKERS env with JSON to inject tokens at runtime
# Example (use real tokens locally):
# export WORKERS='[
#   {"name":"2","bin":"/opt/homebrew/bin/claude","token":"TOKEN_PLACEHOLDER","refreshToken":"REFRESH_PLACEHOLDER","expiresAt":1772621202887},
#   {"name":"3","bin":"/opt/homebrew/bin/claude","token":"TOKEN_PLACEHOLDER","refreshToken":"REFRESH_PLACEHOLDER","expiresAt":1772621203094}
# ]'
#
# Option B: edit your local proxy.config.json (untracked or private) and set tokens there.
# Never commit real tokens.
