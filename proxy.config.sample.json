{
  "server": {
    "port": 8403,
    "authToken": ""
  },
  "workers": [
    {
      "name": "1",
      "bin": "/opt/homebrew/bin/claude",
      "token": "",
      "refreshToken": "",
      "expiresAt": 0,
      "note": "Worker 1 — set token via OAuth flow"
    },
    {
      "name": "2",
      "bin": "/opt/homebrew/bin/claude",
      "token": "",
      "refreshToken": "",
      "expiresAt": 0,
      "note": "Worker 2 — set token via OAuth flow"
    }
  ],
  "routing": {
    "primaryWorker": "1",
    "useCliAgents": false,
    "healthCheckMs": 600000,
    "loadBalance": false,
    "allowExplicitTokenOverride": true
  },
  "sessionAffinity": {
    "ttlMs": 1800000
  },
  "cacheControl": {
    "enabled": true,
    "systemPrefixChars": 1200,
    "minSystemPrefixChars": 200,
    "keyMaxEntries": 5000,
    "normalizeSystemPrefix": true,
    "debounceWhitespace": true,
    "sessionScope": "x-session-id"
  },
  "queue": {
    "maxConcurrent": 6,
    "maxQueueTotal": 200,
    "maxQueuePerSource": 50,
    "queueTimeoutMs": 300000,
    "sourceConcurrencyLimits": {},
    "defaultSourceConcurrency": 0
  },
  "timeouts": {
    "streamTimeoutMs": 7200000,
    "syncTimeoutMs": 1800000
  },
  "retry": {
    "maxRetries": 3,
    "retryBaseMs": 2000
  },
  "process": {
    "maxProcessAgeMs": 7200000,
    "maxIdleMs": 3600000,
    "reaperIntervalMs": 15000
  },
  "warmPool": {
    "enabled": false,
    "size": 0,
    "maxAgeMs": 300000
  },
  "rateLimits": {
    "sonnet": {
      "requestsPerMin": 57,
      "tokensPerMin": 190000
    },
    "opus": {
      "requestsPerMin": 28,
      "tokensPerMin": 57000
    },
    "haiku": {
      "requestsPerMin": 95,
      "tokensPerMin": 380000
    }
  },
  "anthropic": {
    "apiBase": "https://api.anthropic.com",
    "apiVersion": "2023-06-01",
    "models": {
      "sonnet": "claude-sonnet-4-6",
      "opus": "claude-opus-4-6",
      "haiku": "claude-haiku-4-5-20251001"
    }
  },
  "fallback": {
    "baseUrl": "",
    "apiKey": "",
    "model": "",
    "name": ""
  },
  "limits": {
    "maxPromptChars": 50000,
    "maxPromptTokens": 190000,
    "maxBodyBytes": 5000000
  },
  "systemReaper": {
    "intervalMs": 300000,
    "shellMaxAgeSec": 1800,
    "proxyIdleThresholdSec": 600,
    "cliMinAgeSec": 300,
    "helperMinAgeSec": 1800
  },
  "heartbeat": {
    "opus": 600000,
    "sonnet": 300000,
    "haiku": 180000,
    "default": 300000
  },
  "dashboard": {
    "version": "0.7.0",
    "refreshMs": 2000,
    "historyRefreshMs": 10000,
    "reaperRefreshMs": 30000,
    "eventsLimit": 100
  },
  "portal": {
    "openclawPort": 8877,
    "healthPollMs": 5000,
    "iframeTimeoutMs": 8000
  }
}
